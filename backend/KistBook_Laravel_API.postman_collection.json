          "name": "Installment Plan Sync Upload - Update",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"plans\": [\n    {\n      \"serverId\": \"{{installment_plan_id}}\",\n      \"customerId\": \"{{customer_id}}\",\n      \"mode\": \"common\",\n      \"selectedProducts\": [\n        { \"productId\": \"{{product_id}}\", \"quantity\": 1, \"agreedPrice\": 10000 }\n      ],\n      \"commonDeposit\": 1200,\n      \"commonInstallmentAmount\": 3000,\n      \"commonFrequencyInDays\": 30,\n      \"commonFirstDueDate\": \"2026-06-01\",\n      \"note\": \"Updated offline mobile plan\"\n    }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/installment-plans/sync", "host": ["{{base_url}}"], "path": ["installment-plans", "sync"] }
          }
        },
        {
          "name": "Installment Plan Sync Upload - Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"plans\": [\n    { \"serverId\": \"{{installment_plan_id}}\" }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/installment-plans/sync", "host": ["{{base_url}}"], "path": ["installment-plans", "sync"] }
          }
        },
        {
          "name": "Installment Plan List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/installment-plans?perPage=15", "host": ["{{base_url}}"], "path": ["installment-plans"], "query": [{ "key": "perPage", "value": "15" }] }
          }
        },
        {
          "name": "Installment Plan Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/installment-plans/{{installment_plan_id}}", "host": ["{{base_url}}"], "path": ["installment-plans", "{{installment_plan_id}}"] }
