          "name": "Delete Installment Plan",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/installment-plans/{{installment_plan_id}}", "host": ["{{base_url}}"], "path": ["installment-plans", "{{installment_plan_id}}"] }
          }
        },
        {
          "name": "Installment Plan Sync Download",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/installment-plans/sync?lastUpdatedAt=2001-01-01T00:00:00.000Z&limit=10", "host": ["{{base_url}}"], "path": ["installment-plans", "sync"], "query": [{ "key": "lastUpdatedAt", "value": "2001-01-01T00:00:00.000Z" }, { "key": "lastServerId", "value": "", "disabled": true }, { "key": "limit", "value": "10" }] }
          }
        },
